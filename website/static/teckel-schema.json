        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "readers": { "type": "array" },
            "transformers": { "type": "array" },
            "writers": { "type": "array" }
          }
        }
      }
    },
    "NotificationTarget": {
      "type": "object",
      "required": ["channel"],
      "additionalProperties": false,
      "properties": {
